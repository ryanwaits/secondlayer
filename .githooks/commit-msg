#!/bin/sh
# Enforce the /done commit convention: a single-line conventional-commit subject,
# no body. Multi-line messages keep slipping in (agents/skills don't always hold
# the line), so this blocks them at commit time. Bypass for a one-off with
# `git commit --no-verify`.

msg_file="$1"

# Content lines only: drop git's comment lines (#...) and blank lines.
content=$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d')
subject=$(printf '%s\n' "$content" | sed -n '1p')

# Merge/revert/fixup commits carry tool-generated bodies — let them through.
case "$subject" in
	"Merge "* | "Revert "* | "fixup! "* | "squash! "*) exit 0 ;;
esac

# Block any body (more than one non-empty, non-comment line).
if [ "$(printf '%s\n' "$content" | grep -c .)" -gt 1 ]; then
	echo "✖ commit-msg: multi-line commit messages are not allowed (/done rule: single line)." >&2
	echo "  Collapse to one concise conventional-commit subject. Offending body:" >&2
	printf '%s\n' "$content" | sed -n '2,$p' | sed 's/^/    /' >&2
	echo "  (bypass once with: git commit --no-verify)" >&2
	exit 1
fi

# Subject must be a conventional commit: type(scope)?: description
if ! printf '%s' "$subject" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9 ._/-]+\))?!?: .+'; then
	echo "✖ commit-msg: subject must be a conventional commit — type(scope): description" >&2
	echo "    got:   $subject" >&2
	echo "    types: feat fix docs style refactor perf test build ci chore revert" >&2
	exit 1
fi

exit 0
