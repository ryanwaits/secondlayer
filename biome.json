{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": ["**/dist/**", "**/node_modules/**", "**/.next/**", "**/build/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": {
				"noAutofocus": "off"
			}
		}
	},
	"organizeImports": {
		"enabled": true
	}
}
