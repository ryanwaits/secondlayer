{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": [
			"**/dist/**",
			"**/node_modules/**",
			"**/.next/**",
			"**/build/**",
			"packages/subgraphs/test/fixtures/blockdata-8100000-8100100.json",
			".cadence/**",
			".vercel/**",
			".claude/**",
			".impeccable/**",
			".mcp.json",
			"skills-lock.json",
			"skills/**",
			"docs/mocks/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"a11y": {
				"noAutofocus": "off"
			}
		}
	},
	"organizeImports": {
		"enabled": true
	},
	"overrides": [
		{
			"include": ["**/*.test.ts", "**/test/**/*.ts"],
			"linter": {
				"rules": {
					"performance": {
						"noDelete": "off"
					}
				}
			}
		}
	]
}
