# Caddy config — single platform host post 2026-05-14 shared-rip.
#
# Backend routing:
#   api.{BASE_DOMAIN}   →  api:3800   (`/hooks/slack*` → agent:3900)
{
	email {$CADDY_ACME_EMAIL:ryan.waits@gmail.com}
}

api.{$BASE_DOMAIN:secondlayer.tools} {
	header -Server
	header X-Content-Type-Options nosniff

	# Access log → rotated file on the caddy_logs volume. `remote_ip` is the real
	# client IP (Linux iptables DNAT preserves source through the published port),
	# so this is the source of truth for unique-IP / top-path analytics until the
	# Loki+Alloy log plane (Phase 1) ships these lines centrally. JSON so it greps
	# with `jq` and ingests into Loki unchanged.
	log {
		output file /var/log/caddy/access.log {
			roll_size 50MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}

	handle /hooks/slack* {
		reverse_proxy agent:3900
	}
	handle {
		# Load-balance across all `api` replicas. `dynamic a` re-resolves the
		# service name against Docker's embedded DNS (127.0.0.11) every refresh,
		# so replicas added/removed during a rolling deploy enter/leave the pool
		# automatically. Passive failover (fail_duration) drops a replica that's
		# mid-recreate and retries the next within lb_try_duration → no 502.
		reverse_proxy {
			dynamic a {
				name api
				port 3800
				refresh 2s
			}
			lb_policy round_robin
			fail_duration 10s
			lb_try_duration 5s
			lb_try_interval 250ms
		}
	}
}
