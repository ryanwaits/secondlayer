# Hetzner AX52 Deployment Configuration
# Copy to .env and fill in values

COMPOSE_PROJECT_NAME=secondlayer

POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=secondlayer

# Base domain. Caddy serves `api.{BASE_DOMAIN}` + wildcard `*.{BASE_DOMAIN}`
# (tenant subdomains). Requires a wildcard A record (`*` and `api` → SERVER_IP).
BASE_DOMAIN=your-domain.example.com
CADDY_ACME_EMAIL=you@your-domain.example.com
SERVER_IP=your.server.ip.here

LOG_LEVEL=info
NETWORKS=mainnet

# Internal Streams key used only by the L2 decoder service.
STREAMS_INTERNAL_API_KEY=CHANGE_ME

# ed25519 private key (PKCS8 PEM) for signing Streams responses. When set, the
# API signs every Streams read with X-Signature and serves the public key at
# /public/streams/signing-key. Leave unset to disable signing (no headers).
# Store the PEM as a single line with literal \n between lines, e.g.
#   STREAMS_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4...\n-----END PRIVATE KEY-----\n"
STREAMS_SIGNING_PRIVATE_KEY=

# Storage paths
DATA_DIR=/opt/secondlayer/data

# Hiro API (remote fallback for gap-fill)
HIRO_API_KEY=

# Tip follower — disable during genesis sync, enable after caught up
TIP_FOLLOWER_ENABLED=true

# Auth (magic link emails)
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=Second Layer <noreply@secondlayer.tools>

# Hetzner Storage Box (offsite backups)
STORAGEBOX_USER=uXXXXXX
STORAGEBOX_HOST=uXXXXXX.your-storagebox.de
STORAGEBOX_PATH=backups
STORAGEBOX_PORT=23

# WAL-G database backups → R2 (point-in-time recovery). See
# docs/runbook/db-backup-restore.md. By default the walg-backup sidecar reuses
# the STREAMS_BULK_R2_* creds below; override here only if you mint scoped creds.
# WALG_S3_PREFIX MUST be a SEPARATE PRIVATE bucket from the public dumps bucket.
WALG_S3_PREFIX=s3://secondlayer-db-backups/pg
# WALG_R2_ACCESS_KEY_ID=        # optional override (else uses STREAMS_BULK_R2_ACCESS_KEY_ID)
# WALG_R2_SECRET_ACCESS_KEY=    # optional override
# WALG_R2_ENDPOINT=             # optional override (https://<acct>.r2.cloudflarestorage.com)
WALG_RETAIN_FULL=4             # keep last 4 weekly base backups (~1 month)
WALG_BACKUP_INTERVAL_SECS=604800  # weekly base backup; WAL gives second-level PITR regardless

# Agent (AI DevOps monitoring)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX
SLACK_API_TOKEN=xoxb-XXXXX
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_SIGNING_SECRET=
ANTHROPIC_API_KEY=sk-ant-XXXXX
AGENT_DRY_RUN=false
AGENT_AI_ENABLED=true
AGENT_POLL_INTERVAL_MS=300000
AGENT_BUDGET_CAP_DAILY_USD=5
NODE_SERVER_URL=http://<node-server-ip>
