# Hetzner AX52 Deployment Configuration
# Copy to .env and fill in values

COMPOSE_PROJECT_NAME=secondlayer

POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=secondlayer

DOMAIN=your-domain.example.com
SERVER_IP=your.server.ip.here

LOG_LEVEL=info
WORKER_CONCURRENCY=10
WORKER_REPLICAS=1
NETWORKS=mainnet

# Storage paths
DATA_DIR=/opt/secondlayer/data
# CHAINSTATE_DIR - Set to separate mount point if using additional NVMe for blockchain data
# Example: CHAINSTATE_DIR=/mnt/chainstate
# If unset, defaults to $DATA_DIR/stacks-blockchain

# Auth (magic link emails)
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=Second Layer <noreply@secondlayer.tools>

# Hetzner Storage Box (offsite backups)
STORAGEBOX_USER=uXXXXXX
STORAGEBOX_HOST=uXXXXXX.your-storagebox.de
STORAGEBOX_PATH=backups
STORAGEBOX_PORT=23

# Agent (AI DevOps monitoring)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX
ANTHROPIC_API_KEY=sk-ant-XXXXX
AGENT_DRY_RUN=false
AGENT_AI_ENABLED=true
AGENT_POLL_INTERVAL_MS=300000
AGENT_BUDGET_CAP_DAILY_USD=5
