# Project
COMPOSE_PROJECT_NAME=secondlayer

# PostgreSQL
POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=secondlayer
POSTGRES_DB=secondlayer
POSTGRES_PORT=5432

# Service ports
API_PORT=3800
INDEXER_PORT=3700

# Logging
LOG_LEVEL=info

# Email (for magic link auth)
RESEND_API_KEY=
EMAIL_FROM=Second Layer <noreply@secondlayer.tools>

# Networks
NETWORKS=mainnet

# Hiro API (remote fallback for gap-fill)
HIRO_API_URL=https://api.mainnet.hiro.so
HIRO_API_KEY=

# Tip follower (polls Hiro when node goes silent)
TIP_FOLLOWER_ENABLED=true
# TIP_FOLLOWER_TIMEOUT=60
# TIP_FOLLOWER_MAX_BLOCKS=10

# Stripe billing (platform mode only)
# - Restricted key in sandbox first, live later.
# - WEBHOOK_SECRET is printed by `stripe listen --forward-to localhost:3800/api/webhooks/stripe`
#   for local dev; live value comes from the Stripe dashboard webhook config.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price + meter ids emitted by `bun run scripts/stripe-setup.ts`. Populate
# after running the setup script against your target environment. Enterprise
# is custom-quoted per deal and doesn't have a shared price id.
STRIPE_PRICE_PRO=
STRIPE_METER_COMPUTE=
STRIPE_METER_STORAGE=
STRIPE_METER_AI_EVALS=
STRIPE_PRICE_COMPUTE_OVERAGE=
STRIPE_PRICE_STORAGE_OVERAGE=
STRIPE_PRICE_AI_OVERAGE=
