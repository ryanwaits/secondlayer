# Project
COMPOSE_PROJECT_NAME=secondlayer

# PostgreSQL
POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=secondlayer
POSTGRES_DB=secondlayer
POSTGRES_PORT=5432

# Service ports
API_PORT=3800
INDEXER_PORT=3700

# Internal Streams key used only by the L2 decoder service.
STREAMS_INTERNAL_API_KEY=sk-sl_streams_enterprise_test

# Shared rate-limit store. Defaults to the compose `redis` service. Unset for
# process-local limits (single API instance only). The API fails OPEN — a Redis
# outage stops enforcing limits rather than 503-ing requests.
REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=info

# Email (for magic link auth)
RESEND_API_KEY=
EMAIL_FROM=Second Layer <noreply@secondlayer.tools>

# Networks
NETWORKS=mainnet

# Hiro API — used ONLY by manual backfill/repair scripts (bulk-backfill, repair-transactions),
# never by the live services. Leave unset for a Hiro-free deployment; the running plane
# (ingestion, integrity auto-backfill, tip-follower) sources entirely from the own stacks-node.
HIRO_API_URL=
HIRO_API_KEY=

# Tip follower (re-syncs from the own stacks-node + local DB when the node goes silent)
TIP_FOLLOWER_ENABLED=true
# TIP_FOLLOWER_TIMEOUT=60
# TIP_FOLLOWER_MAX_BLOCKS=10

# Stripe billing (platform mode only)
# - Restricted key in sandbox first, live later.
# - WEBHOOK_SECRET is printed by `stripe listen --forward-to localhost:3800/api/webhooks/stripe`
#   for local dev; live value comes from the Stripe dashboard webhook config.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Tier price ids emitted by `bun run scripts/stripe-setup.ts`. Populate
# after running the setup script against your target environment. Hobby is
# free (no Stripe sub); Enterprise is custom-quoted per deal. PAYG credit
# top-ups use inline price_data — no pre-created price id needed.
STRIPE_PRICE_LAUNCH=
STRIPE_PRICE_LAUNCH_YEARLY=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_SCALE_YEARLY=
