# Project
COMPOSE_PROJECT_NAME=secondlayer

# PostgreSQL
POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=secondlayer
POSTGRES_DB=secondlayer
POSTGRES_PORT=5432

# Service ports
API_PORT=3800
INDEXER_PORT=3700

# Logging
LOG_LEVEL=info

# Email (for magic link auth)
RESEND_API_KEY=
EMAIL_FROM=Second Layer <noreply@secondlayer.tools>

# Networks
NETWORKS=mainnet

# Hiro API (remote fallback for gap-fill)
HIRO_API_URL=https://api.mainnet.hiro.so
HIRO_API_KEY=

# Tip follower (polls Hiro when node goes silent)
TIP_FOLLOWER_ENABLED=true
# TIP_FOLLOWER_TIMEOUT=60
# TIP_FOLLOWER_MAX_BLOCKS=10
