# Copy to .env and fill in. Start with a strong DB password and bitcoin RPC password.

# Postgres — change the password before exposing the port publicly.
POSTGRES_USER=secondlayer
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=secondlayer
# Bind to localhost by default; remove 127.0.0.1: prefix to expose the DB port.
POSTGRES_PORT=127.0.0.1:5432

# API service (always on; staticKeyAuth gates access when API_KEY is set)
API_PORT=3800
# Uncomment to require a Bearer token on every request:
# API_KEY=sl_oss_replace_with_random_32char_hex

# Indexer — bound to localhost; stacks-node uses the docker network.
INDEXER_PORT=127.0.0.1:3700

# Stacks network (mainnet or testnet). Comma-separated for multi-network.
NETWORKS=mainnet

# Logging
LOG_LEVEL=info

# --- Decoder + subscriptions (decoder + subscription-processor services) ---

# The decoder writes decoded_events (transfers/mints/burns/prints), which power
# /v1/index and chain subscriptions. These have safe defaults; override to tune.
# SBTC_DECODER_ENABLED=true
# POX4_DECODER_ENABLED=true
# BNS_DECODER_ENABLED=false

# Per-subscription secrets (HMAC signing secret + auth_config bearer tokens) are
# encrypted at rest. The api ENCRYPTS them; subscription-processor DECRYPTS them
# to deliver — so BOTH must share ONE key. OSS auto-bootstrap writes a different
# key per container, so set this explicitly to run subscriptions. Generate with:
#   openssl rand -hex 32
# SECONDLAYER_SECRETS_KEY=

# ed25519 key for the x-secondlayer-signature on every webhook delivery (PEM,
# newlines as \n). Without it, deliveries ship UNSIGNED; subscription-processor
# defaults ALLOW_UNSIGNED_WEBHOOKS=true so it still boots. Per-subscription HMAC
# signing is independent and always applies. Set a key to get the platform sig:
# STREAMS_SIGNING_PRIVATE_KEY=
# ALLOW_UNSIGNED_WEBHOOKS=true

# Set to anything other than streams-index to run delivery-only (no chain
# trigger evaluator — webhooks fire only from manually enqueued deliveries).
# SUBGRAPH_SOURCE=streams-index

# --- Stacks + Bitcoin node (only needed if you run the `node` profile) ---

# Bitcoin Core RPC credentials — stacks-node authenticates to bitcoind with these.
# Must match the rpcuser/rpcpassword in bitcoin.conf.
BITCOIN_RPC_USER=stacks
BITCOIN_RPC_PASSWORD=changeme_bitcoin_rpc_password

# Data volume hosts — override to point at a fast NVMe mount in production.
BITCOIN_DATA_DIR=./data/bitcoin
STACKS_DATA_DIR=./data/stacks
