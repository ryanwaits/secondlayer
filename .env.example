# Secondlayer — local environment template.
#
# The local dev stack is just Postgres:
#   bun run db        # boots docker/docker-compose.dev.yml (host 5440 -> container 5432)
#   bun run migrate   # applies migrations (DATABASE_URL hardcoded to the same target)
#
# Bun auto-loads .env from the CURRENT working directory, and repo scripts run
# per-package — so the .env files that matter live in packages, not here:
#   cp packages/api/.env.example packages/api/.env
#   cp packages/shared/.env.example packages/shared/.env
#
# A root .env is only picked up by scripts run from the repo root
# (e.g. `bun run konsole`). If you want those to hit the docker stack too:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5440/secondlayer
