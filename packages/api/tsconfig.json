{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {
			"@secondlayer/indexer/streams-tip": ["../indexer/src/streams-tip.ts"],
			"@secondlayer/indexer/streams-events": [
				"../indexer/src/streams-events.ts"
			],
			"@secondlayer/indexer/decode/decoder": [
				"../indexer/src/decode/decoder.ts"
			],
			"@secondlayer/indexer/decode/health": ["../indexer/src/decode/health.ts"],
			"@secondlayer/indexer/decode/internal-auth": [
				"../indexer/src/decode/internal-auth.ts"
			],
			"@secondlayer/sdk": ["../sdk/src/index.ts"],
			"@secondlayer/sdk/*": ["../sdk/src/*"],
			"@secondlayer/shared": ["../shared/src/index.ts"],
			"@secondlayer/shared/*": ["../shared/src/*"],
			"@secondlayer/stacks": ["../stacks/src/index.ts"],
			"@secondlayer/stacks/*": ["../stacks/src/*"],
			"@secondlayer/subgraphs": ["../subgraphs/src/index.ts"],
			"@secondlayer/subgraphs/*": ["../subgraphs/src/*"]
		}
	},
	"include": [
		"src/**/*",
		"../indexer/src/decode/**/*",
		"../indexer/src/streams-events.ts",
		"../indexer/src/streams-tip.ts",
		"../sdk/src/**/*",
		"../shared/src/**/*",
		"../stacks/src/**/*",
		"../subgraphs/src/**/*"
	],
	"exclude": ["node_modules", "dist"]
}
