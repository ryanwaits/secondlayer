{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {
			"@secondlayer/indexer/streams-tip": [
				"../indexer/src/streams-tip.ts"
			],
			"@secondlayer/indexer/streams-events": [
				"../indexer/src/streams-events.ts"
			],
			"@secondlayer/indexer/l2/decoder": [
				"../indexer/src/l2/decoder.ts"
			],
			"@secondlayer/indexer/l2/streams-client": [
				"../indexer/src/l2/streams-client.ts"
			],
			"@secondlayer/shared": ["../shared/src/index.ts"],
			"@secondlayer/shared/*": ["../shared/src/*"],
			"@secondlayer/subgraphs": ["../subgraphs/src/index.ts"],
			"@secondlayer/subgraphs/*": ["../subgraphs/src/*"]
		}
	},
	"include": [
		"src/**/*",
		"../indexer/src/l2/**/*",
		"../indexer/src/streams-events.ts",
		"../indexer/src/streams-tip.ts",
		"../shared/src/**/*",
		"../subgraphs/src/**/*"
	],
	"exclude": ["node_modules", "dist"]
}
