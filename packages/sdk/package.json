{
	"name": "@secondlayer/sdk",
	"version": "6.26.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryanwaits/secondlayer.git",
		"directory": "packages/sdk"
	},
	"homepage": "https://github.com/ryanwaits/secondlayer/tree/main/packages/sdk#readme",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./streams": {
			"types": "./dist/streams/index.d.ts",
			"import": "./dist/streams/index.js"
		},
		"./subgraphs": {
			"types": "./dist/subgraphs/index.d.ts",
			"import": "./dist/subgraphs/index.js"
		},
		"./x402": {
			"types": "./dist/x402.d.ts",
			"import": "./dist/x402.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@secondlayer/shared": "^6.36.0",
		"@secondlayer/stacks": "^2.5.1",
		"@secondlayer/subgraphs": "^3.15.2"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
