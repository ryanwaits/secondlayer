{
	"name": "@secondlayer/sdk",
	"version": "0.9.1",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./streams": {
			"types": "./dist/streams/index.d.ts",
			"import": "./dist/streams/index.js"
		},
		"./subgraphs": {
			"types": "./dist/subgraphs/index.d.ts",
			"import": "./dist/subgraphs/index.js"
		},
		"./marketplace": {
			"types": "./dist/marketplace/index.d.ts",
			"import": "./dist/marketplace/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@secondlayer/shared": "^0.10.1",
		"@secondlayer/subgraphs": "^0.9.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
