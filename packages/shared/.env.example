# Copy to .env in this directory (`cp .env.example .env`).
# Bun auto-loads it for any script/test run from this package.
#
# Local Postgres from the dev compose stack — boot it from the repo root
# with `bun run db` (docker/docker-compose.dev.yml maps host 5440 -> 5432):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5440/secondlayer
