{
	"name": "@secondlayer/platform",
	"version": "0.1.6",
	"private": true,
	"type": "module",
	"exports": {
		"./pricing": {
			"types": "./dist/pricing.d.ts",
			"import": "./dist/pricing.js"
		},
		"./db/queries/accounts": {
			"types": "./dist/db/queries/accounts.d.ts",
			"import": "./dist/db/queries/accounts.js"
		},
		"./db/queries/usage": {
			"types": "./dist/db/queries/usage.d.ts",
			"import": "./dist/db/queries/usage.js"
		},
		"./db/queries/account-spend-caps": {
			"types": "./dist/db/queries/account-spend-caps.d.ts",
			"import": "./dist/db/queries/account-spend-caps.js"
		},
		"./db/queries/account-credits": {
			"types": "./dist/db/queries/account-credits.d.ts",
			"import": "./dist/db/queries/account-credits.js"
		},
		"./db/queries/projects": {
			"types": "./dist/db/queries/projects.d.ts",
			"import": "./dist/db/queries/projects.js"
		},
		"./schemas/accounts": {
			"types": "./dist/schemas/accounts.d.ts",
			"import": "./dist/schemas/accounts.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@secondlayer/shared": "workspace:*",
		"kysely": "0.28.15",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
