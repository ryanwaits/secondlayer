{
	"name": "@secondlayer/signer-node",
	"version": "0.1.0",
	"description": "Reference Node/Bun signing service for Secondlayer workflows. Customer-hosted: your private key never leaves your infrastructure.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./policy": {
			"types": "./dist/policy.d.ts",
			"import": "./dist/policy.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"examples"
	],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@stacks/transactions": "^7.4.0",
		"hono": "^4.9.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
