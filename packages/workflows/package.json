{
	"name": "@secondlayer/workflows",
	"version": "2.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		},
		"./ai": {
			"types": "./dist/ai.d.ts",
			"import": "./dist/ai.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "3.0.71",
		"ai": "6.0.167",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
