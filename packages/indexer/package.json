{
	"name": "@secondlayer/indexer",
	"version": "1.12.6",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./streams-tip": {
			"types": "./src/streams-tip.ts",
			"import": "./src/streams-tip.ts"
		},
		"./streams-events": {
			"types": "./src/streams-events.ts",
			"import": "./src/streams-events.ts"
		},
		"./decode/decoder": {
			"types": "./src/decode/decoder.ts",
			"import": "./src/decode/decoder.ts"
		},
		"./decode/health": {
			"types": "./src/decode/health.ts",
			"import": "./src/decode/health.ts"
		},
		"./decode/internal-auth": {
			"types": "./src/decode/internal-auth.ts",
			"import": "./src/decode/internal-auth.ts"
		}
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun run --watch src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1042.0",
		"@dsnp/parquetjs": "^1.8.8",
		"@secondlayer/sdk": "^6.29.1",
		"@secondlayer/shared": "^7.0.0",
		"@secondlayer/stacks": "^2.14.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
