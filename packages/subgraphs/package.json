{
	"name": "@secondlayer/subgraphs",
	"version": "1.0.0",
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		},
		"./types": {
			"types": "./dist/src/types.d.ts",
			"import": "./dist/src/types.js"
		},
		"./schema": {
			"types": "./dist/src/schema/index.d.ts",
			"import": "./dist/src/schema/index.js"
		},
		"./validate": {
			"types": "./dist/src/validate.d.ts",
			"import": "./dist/src/validate.js"
		},
		"./runtime/source-matcher": {
			"types": "./dist/src/runtime/source-matcher.d.ts",
			"import": "./dist/src/runtime/source-matcher.js"
		},
		"./runtime/replay": {
			"types": "./dist/src/runtime/replay.d.ts",
			"import": "./dist/src/runtime/replay.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@secondlayer/shared": "^3.0.0",
		"@secondlayer/stacks": "^1.0.0",
		"kysely": "0.28.15",
		"postgres": "^3.4.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
