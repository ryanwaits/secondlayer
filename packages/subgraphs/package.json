{
	"name": "@secondlayer/subgraphs",
	"version": "3.14.4",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryanwaits/secondlayer.git",
		"directory": "packages/subgraphs"
	},
	"homepage": "https://github.com/ryanwaits/secondlayer/tree/main/packages/subgraphs#readme",
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		},
		"./types": {
			"types": "./dist/src/types.d.ts",
			"import": "./dist/src/types.js"
		},
		"./schema": {
			"types": "./dist/src/schema/index.d.ts",
			"import": "./dist/src/schema/index.js"
		},
		"./validate": {
			"types": "./dist/src/validate.d.ts",
			"import": "./dist/src/validate.js"
		},
		"./triggers": {
			"types": "./dist/src/triggers/index.d.ts",
			"import": "./dist/src/triggers/index.js"
		},
		"./runtime/source-matcher": {
			"types": "./dist/src/runtime/source-matcher.d.ts",
			"import": "./dist/src/runtime/source-matcher.js"
		},
		"./runtime/replay": {
			"types": "./dist/src/runtime/replay.d.ts",
			"import": "./dist/src/runtime/replay.js"
		},
		"./runtime/emitter": {
			"types": "./dist/src/runtime/emitter.d.ts",
			"import": "./dist/src/runtime/emitter.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "bunup",
		"dev": "bunup --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@secondlayer/shared": "^6.33.2",
		"@secondlayer/stacks": "^2.3.0",
		"kysely": "0.28.15",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"publishConfig": {
		"access": "public"
	}
}
